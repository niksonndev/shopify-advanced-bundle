{%- comment -%}
  Advanced Bundle Builder
  - Stack: Liquid + Tailwind CSS + Alpine.js
  - Requisitos:
    * Tailwind CSS disponível no tema (build ou CDN)
    * Alpine.js v3 carregado globalmente (ex: <script src="https://unpkg.com/alpinejs" defer></script>)
  - Uso: adicione esta section em qualquer template; escolha a coleção nas configurações.
{%- endcomment -%}

{%- liquid
  assign bundle_collection = section.settings.collection
  if bundle_collection == blank
    assign bundle_collection = collection
  endif
  assign required_items = section.settings.required_items | default: 3
  assign discount_percentage = section.settings.discount_percentage | default: 15
  assign heading_title = section.settings.heading_title | default: 'Monte seu pacote e ganhe'
  assign heading_highlight = section.settings.heading_highlight | default: '15% OFF'
  assign subheading = section.settings.subheading | default: 'Selecione exatamente 3 produtos desta coleção para desbloquear o desconto automático no carrinho.'
-%}

{%- comment -%} Build JSON array of products (first available variant + product info) for Alpine {%- endcomment -%}
{%- capture products_json -%}
[
  {%- if bundle_collection.products.size > 0 -%}
    {%- for product in bundle_collection.products -%}
      {%- assign v = product.first_available_variant -%}
      {%- if v -%}
        {
          "id": {{ v.id }},
          "name": {{ product.title | json }},
          "price": {{ v.price | times: 100 | round }},
          "sku": {{ v.sku | default: '' | json }},
          "featured_image": {%- if product.featured_image -%}
            {"src": {{ product.featured_image | image_url: width: 600 | json }}, "alt": {{ product.featured_image.alt | default: product.title | json }}}
          {%- else -%}
            null
          {%- endif -%}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
]
{%- endcapture -%}

<section
  class="bg-slate-50 py-12"
  x-data="bundleBuilder({
    products: {{ products_json | strip_newlines }},
    requiredItems: {{ required_items }},
    discountPercentage: {{ discount_percentage }},
    currency: {{ shop.currency | json }}
  })"
  x-init="init()"
  {{ section.shopify_attributes }}
>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-3 text-center sm:mb-10">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
        {{ heading_title }}
        <span class="text-emerald-600">{{ heading_highlight }}</span>
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-slate-600 sm:text-base">
        {{ subheading }}
      </p>
    </div>

    <div class="mb-8 space-y-3">
      <div class="flex items-center justify-between text-xs font-medium uppercase tracking-wide text-slate-600">
        <span>
          Itens selecionados:
          <span class="font-semibold text-slate-900" x-text="totalSelected"></span>
          /
          <span class="font-semibold text-slate-900" x-text="requiredItems"></span>
        </span>
        <span
          class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold"
          :class="canCheckout()
            ? 'bg-emerald-100 text-emerald-800'
            : 'bg-slate-100 text-slate-700'"
        >
          <span class="mr-1.5 h-2.5 w-2.5 rounded-full"
                :class="canCheckout() ? 'bg-emerald-500' : 'bg-slate-400'"></span>
          <span x-show="!canCheckout()">Complete seu pacote</span>
          <span x-show="canCheckout()">Pacote pronto com desconto</span>
        </span>
      </div>

      <div class="h-2 w-full overflow-hidden rounded-full bg-slate-200">
        <div
          class="h-full rounded-full bg-emerald-500 transition-all duration-300"
          :style="`width: ${progressPercentage()}%`"
        ></div>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <template x-for="product in products" :key="product.id">
        <article
          class="group relative flex cursor-pointer flex-col overflow-hidden rounded-2xl border bg-white shadow-sm transition-all duration-200"
          :class="isSelected(product.id)
            ? 'border-emerald-500 ring-2 ring-emerald-200'
            : 'border-slate-200 hover:border-slate-300 hover:shadow-md'"
          @click="toggleProduct(product)"
        >
          <div class="absolute right-3 top-3 z-10">
            <span
              class="inline-flex h-7 w-7 items-center justify-center rounded-full border text-[11px] font-semibold"
              :class="isSelected(product.id)
                ? 'border-emerald-500 bg-emerald-500 text-white'
                : 'border-slate-300 bg-white text-slate-500'"
            >
              <svg x-show="isSelected(product.id)" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd"
                  d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.333a1 1 0 0 1-1.432.006L3.29 9.29A1 1 0 0 1 4.704 7.88l3.01 3.01 6.536-6.536a1 1 0 0 1 1.414-.006z"
                  clip-rule="evenodd" />
              </svg>
              <span x-show="!isSelected(product.id)">+</span>
            </span>
          </div>

          <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
            <img
              x-show="product.featured_image"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              :src="product.featured_image?.src"
              :alt="product.featured_image?.alt || product.name"
              loading="lazy"
            >
            <div
              x-show="!product.featured_image"
              class="flex h-full w-full items-center justify-center text-xs text-slate-400"
            >
              Sem imagem
            </div>
          </div>

          <div class="flex flex-1 flex-col p-4">
            <h3 class="mb-1 line-clamp-2 text-sm font-semibold text-slate-900">
              <span x-text="product.name"></span>
            </h3>

            <p class="mb-2 text-xs text-slate-500" x-text="product.sku"></p>

            <div class="mt-auto flex items-center justify-between pt-2">
              <div class="flex flex-col">
                <span class="text-sm font-semibold text-slate-900" x-text="formatPrice(product.price)"></span>
                <span class="text-[11px] text-slate-500">
                  {{ shop.money_format | strip_html }}
                </span>
              </div>

              <button
                type="button"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold transition-colors"
                :class="isSelected(product.id)
                  ? 'border-emerald-500 bg-emerald-50 text-emerald-700'
                  : 'border-slate-200 bg-slate-50 text-slate-700 group-hover:border-slate-300'"
              >
                <span x-show="!isSelected(product.id)">Adicionar</span>
                <span x-show="isSelected(product.id)">Remover</span>
              </button>
            </div>
          </div>
        </article>
      </template>
    </div>

    {%- if bundle_collection.products.size == 0 -%}
      <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-600">
        <p>Nenhum produto disponível nesta coleção. Selecione outra coleção nas configurações da seção.</p>
      </div>
    {%- endif -%}

    <div class="mt-10 grid gap-6 border-t border-slate-200 pt-6 md:grid-cols-[minmax(0,2fr),minmax(0,1.2fr)] md:items-end md:gap-10">
      <div class="space-y-3 text-sm">
        <p class="text-slate-600">
          Selecione exatamente
          <span class="font-semibold" x-text="requiredItems"></span>
          produtos para aplicar automaticamente
          <span class="font-semibold" x-text="discountPercentage + '%'"></span>
          de desconto sobre o subtotal.
        </p>

        <div x-show="errorMessage" class="flex items-start gap-2 rounded-lg border border-red-100 bg-red-50 px-3 py-2 text-xs text-red-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
              d="M9.401 2.034a1 1 0 0 1 1.198 0l7 5.25A1 1 0 0 1 17.8 9H2.2a1 1 0 0 1-.8-1.716l7-5.25zM3 10a1 1 0 0 1 1-1h12a1 1 0 0 1 .894 1.447l-2.5 5A1 1 0 0 1 13.5 16h-7a1 1 0 0 1-.894-.553l-2.5-5A1 1 0 0 1 3 10z"
              clip-rule="evenodd" />
          </svg>
          <span x-text="errorMessage"></span>
        </div>

        <div x-show="successMessage" class="flex items-start gap-2 rounded-lg border border-emerald-100 bg-emerald-50 px-3 py-2 text-xs text-emerald-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
              d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm3.707-9.707a1 1 0 0 0-1.414-1.414L9 10.172 7.707 8.879a1 1 0 1 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4z"
              clip-rule="evenodd" />
          </svg>
          <span x-text="successMessage"></span>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
        <dl class="space-y-2 text-sm">
          <div class="flex items-center justify-between text-slate-600">
            <dt>Subtotal (sem desconto)</dt>
            <dd class="font-medium text-slate-900" x-text="formatPrice(subtotal)"></dd>
          </div>
          <div class="flex items-center justify-between text-slate-600">
            <dt>Desconto do pacote</dt>
            <dd class="font-medium text-emerald-700" x-text="canCheckout() ? '-' + formatPrice(discountAmount) : formatPrice(0)"></dd>
          </div>
          <div class="flex items-center justify-between border-t border-dashed border-slate-200 pt-2 text-sm font-semibold">
            <dt>Total com desconto</dt>
            <dd class="text-slate-900" x-text="formatPrice(finalTotal)"></dd>
          </div>
        </dl>

        <button
          type="button"
          class="mt-4 flex w-full items-center justify-center rounded-full px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all"
          :class="canCheckout()
            ? 'bg-emerald-600 hover:bg-emerald-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2'
            : 'bg-slate-300 cursor-not-allowed'"
          :disabled="!canCheckout() || isAdding"
          :aria-disabled="!canCheckout()"
          @click="addBundleToCart"
        >
          <svg
            x-show="isAdding"
            class="-ml-1 mr-2 h-4 w-4 animate-spin text-white"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v4l3.5-3.5L12 1v4a7 7 0 0 0-7 7h-1z"></path>
          </svg>
          <span x-text="canCheckout() ? (isAdding ? 'Adicionando...' : 'Adicionar pacote ao carrinho') : ('Selecione ' + requiredItems + ' produtos para continuar')"></span>
        </button>

        <p class="mt-2 text-center text-[11px] text-slate-500">
          O checkout é liberado somente quando o pacote está completo.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('bundleBuilder', (config) => ({
      products: config.products || [],
      requiredItems: config.requiredItems || 3,
      discountPercentage: config.discountPercentage || 15,
      currency: config.currency || 'BRL',

      selectedIds: [],
      subtotal: 0,
      discountAmount: 0,
      finalTotal: 0,

      isAdding: false,
      errorMessage: '',
      successMessage: '',

      init() {
        this.products = (this.products || [])
          .filter(p => p && p.id && typeof p.price === 'number');
        this.recalculateTotals();
      },

      get totalSelected() {
        return this.selectedIds.length;
      },

      canCheckout() {
        return this.totalSelected === this.requiredItems;
      },

      progressPercentage() {
        if (!this.requiredItems) return 0;
        return Math.min(100, Math.round((this.totalSelected / this.requiredItems) * 100));
      },

      isSelected(id) {
        return this.selectedIds.includes(id);
      },

      formatPrice(cents) {
        const value = (cents || 0) / 100;
        try {
          return new Intl.NumberFormat(undefined, {
            style: 'currency',
            currency: this.currency
          }).format(value);
        } catch (e) {
          return value.toFixed(2);
        }
      },

      toggleProduct(product) {
        this.clearMessages();
        const id = product.id;
        if (!id) return;

        if (this.isSelected(id)) {
          this.selectedIds = this.selectedIds.filter(vId => vId !== id);
        } else {
          if (this.selectedIds.length >= this.requiredItems) {
            this.errorMessage = `Você só pode selecionar ${this.requiredItems} produtos neste pacote.`;
            return;
          }
          this.selectedIds.push(id);
        }
        this.recalculateTotals();
      },

      recalculateTotals() {
        let subtotal = 0;
        const selectedSet = new Set(this.selectedIds);
        for (const product of this.products) {
          if (selectedSet.has(product.id)) {
            subtotal += product.price || 0;
          }
        }
        this.subtotal = subtotal;

        if (this.canCheckout()) {
          const discount = subtotal * (this.discountPercentage / 100);
          this.discountAmount = Math.round(discount);
        } else {
          this.discountAmount = 0;
        }
        this.finalTotal = Math.max(0, this.subtotal - this.discountAmount);
      },

      clearMessages() {
        this.errorMessage = '';
        this.successMessage = '';
      },

      buildItemsPayload() {
        return this.selectedIds.map(id => ({ id, quantity: 1 }));
      },

      async addBundleToCart() {
        this.clearMessages();
        if (!this.canCheckout()) {
          this.errorMessage = `Selecione exatamente ${this.requiredItems} produtos para completar seu pacote.`;
          return;
        }

        const items = this.buildItemsPayload();
        if (!items.length) return;

        this.isAdding = true;

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ items })
          });

          if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            const message = errorData.description || errorData.message || 'Não foi possível adicionar o pacote ao carrinho.';
            throw new Error(message);
          }

          await response.json();
          this.successMessage = 'Pacote adicionado ao carrinho. Você pode revisar antes de finalizar.';

          if (typeof window.dispatchEvent === 'function') {
            window.dispatchEvent(new CustomEvent('cart:refresh'));
          }
        } catch (error) {
          console.error('[Bundle Builder] addBundleToCart error:', error);
          this.errorMessage = error.message || 'Ocorreu um erro ao adicionar o pacote ao carrinho.';
        } finally {
          this.isAdding = false;
        }
      }
    }));
  });
</script>

{% schema %}
{
  "name": "Advanced Bundle Builder",
  "tag": "section",
  "class": "section-advanced-bundle",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "range",
      "id": "required_items",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Quantidade de itens no pacote"
    },
    {
      "type": "range",
      "id": "discount_percentage",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 15,
      "unit": "%",
      "label": "Desconto do pacote"
    },
    {
      "type": "text",
      "id": "heading_title",
      "label": "Título",
      "default": "Monte seu pacote e ganhe"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Destaque do título",
      "default": "15% OFF"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Selecione exatamente 3 produtos desta coleção para desbloquear o desconto automático no carrinho."
    }
  ],
  "presets": [
    {
      "name": "Advanced Bundle Builder"
    }
  ]
}
{% endschema %}
